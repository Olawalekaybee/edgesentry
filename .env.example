# Copy this file to `.env` and fill in your values. `.env` is git-ignored.

# ── Telegram alerting (reused from v1) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# ── Local LLM (Ollama) ───────────────────────────────────────────────────────
# Ollama runs locally on the Pi. Default endpoint is fine if Ollama is on-device.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# ── Web server ───────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── Paths (override defaults from config.yaml if you want) ───────────────────
# DATA_DIR=./data
